{
  "name": "character-sheet-manager-2",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=github",
    "tailwind:watch": "npx @tailwindcss/cli -i ./tailwind.source.css -o ./src/tailwind.generated.css --watch",
    "tailwind:build": "npx @tailwindcss/cli -i ./tailwind.source.css -o ./src/tailwind.generated.css",
    "dev": "concurrently \"npm run tailwind:watch\" \"ng serve\" --names \"tw,ng\" --prefix-colors \"red,blue\"",
    "screenshot": "node screenshot.js"
  },
  "private": true,
  "packageManager": "npm@11.4.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  }
}